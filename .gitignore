# vim swap files
*.swp
*.swo

# editor backup files
*~

# macOS
.DS_Store

# Local state (never committed; user-specific)
~/.safer/
/.codex

# Skill-creator workspaces (run artifacts; reproducible from evals.json)
skills/*-workspace/
skills/*/evals/iteration-*/

# Per-package node modules and build output for nested LSP packages.
lsp/*/node_modules/
lsp/*/dist/
