#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
SKILLS_DIR="$CODEX_HOME/skills"
PLUGIN_LINK="$SKILLS_DIR/safer-by-default"
BIN_LINK_DIR="${SAFER_CODEX_BIN_DIR:-$HOME/.local/bin}"
STATE_DIR="${SAFER_STATE_DIR:-$HOME/.safer}"
XDG_SOURCE_DIR="${SAFER_XDG_SOURCE_DIR:-$HOME/.local/share/safer-by-default}"
CC_PLUGIN_CACHE="$HOME/.claude/plugins/cache/safer-by-default/safer"
REPO_URL="${SAFER_REPO_URL:-https://github.com/chughtapan/safer-by-default.git}"
MARKER="<!-- safer-by-default codex wrapper -->"

QUIET=0
CHECK_ONLY=0

while [ $# -gt 0 ]; do
  case "$1" in
    --check) CHECK_ONLY=1; shift ;;
    --quiet|-q) QUIET=1; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: ./setup-codex [--check] [--quiet]

Installs Codex compatibility wrappers for the safer-by-default skill bundle.

Source resolution order (Codex has no plugin marketplace, so we need a
canonical on-disk root):
  1. $SAFER_SOURCE_DIR if set (developer escape hatch).
  2. ~/.claude/plugins/cache/safer-by-default/safer/<latest>
     if Claude Code marketplace install is present.
  3. ~/.local/share/safer-by-default (cloned/refreshed from GitHub).

Override locations via env vars:
  SAFER_SOURCE_DIR       skip resolution; use this tree directly
  SAFER_XDG_SOURCE_DIR   change the XDG fallback location
  SAFER_CODEX_BIN_DIR    where to symlink safer-* binaries (default: ~/.local/bin)
  SAFER_REPO_URL         git remote for the XDG fallback clone
  CODEX_HOME             Codex config root (default: ~/.codex)
EOF
      exit 0
      ;;
    *)
      echo "ERROR: unknown flag: $1" >&2
      exit 1
      ;;
  esac
done

log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }
warn() { echo "WARN: $*" >&2; }
err() { echo "ERROR: $*" >&2; }

# Resolve a stable source directory for the safer-by-default install. Codex
# does not have a plugin marketplace, so we need a canonical on-disk root
# for the skills and bin/ helpers. Resolution order:
#   1. $SAFER_SOURCE_DIR — explicit override (developer escape hatch).
#   2. Newest version under $CC_PLUGIN_CACHE — reuse the Claude Code
#      marketplace install if the user already has it.
#   3. $XDG_SOURCE_DIR — if a clone exists there, refresh it; otherwise
#      clone fresh from $REPO_URL.
#
# The resolved path must contain skills/ and bin/. Resolution prints which
# branch was taken so the user can verify.
resolve_source_dir() {
  # Status lines go to stderr; only the resolved path is written to stdout
  # so the caller can use SOURCE_DIR="$(resolve_source_dir)" cleanly.
  if [ -n "${SAFER_SOURCE_DIR:-}" ]; then
    if [ -d "$SAFER_SOURCE_DIR/skills" ] && [ -d "$SAFER_SOURCE_DIR/bin" ]; then
      log "  ✓ using \$SAFER_SOURCE_DIR override: $SAFER_SOURCE_DIR" >&2
      printf '%s\n' "$SAFER_SOURCE_DIR"
      return 0
    fi
    err "\$SAFER_SOURCE_DIR=$SAFER_SOURCE_DIR is not a valid safer-by-default tree"
    return 1
  fi

  if [ -d "$CC_PLUGIN_CACHE" ]; then
    local newest
    newest="$(ls -1 "$CC_PLUGIN_CACHE" 2>/dev/null | sort -V | tail -n1)"
    if [ -n "$newest" ] && [ -d "$CC_PLUGIN_CACHE/$newest/skills" ]; then
      log "  ✓ reusing Claude Code plugin install: $CC_PLUGIN_CACHE/$newest" >&2
      printf '%s\n' "$CC_PLUGIN_CACHE/$newest"
      return 0
    fi
  fi

  if [ "$CHECK_ONLY" -eq 1 ]; then
    if [ -d "$XDG_SOURCE_DIR/skills" ]; then
      log "  ✓ existing XDG clone at $XDG_SOURCE_DIR" >&2
      printf '%s\n' "$XDG_SOURCE_DIR"
      return 0
    fi
    warn "no source dir resolved; would clone $REPO_URL → $XDG_SOURCE_DIR"
    return 1
  fi

  if ! command -v git >/dev/null 2>&1; then
    err "git is required to clone $REPO_URL → $XDG_SOURCE_DIR"
    return 1
  fi

  if [ -d "$XDG_SOURCE_DIR/.git" ]; then
    log "  ↻ refreshing existing clone: $XDG_SOURCE_DIR" >&2
    git -C "$XDG_SOURCE_DIR" fetch --quiet --depth 1 origin HEAD >&2 || warn "git fetch failed; continuing with local clone"
    git -C "$XDG_SOURCE_DIR" reset --quiet --hard FETCH_HEAD 2>/dev/null || true
    # v0.2.0: ensure vendored sister submodule is populated so the contract-init
    # / contract-migrate wrappers can resolve their vendor bodies. Idempotent.
    git -C "$XDG_SOURCE_DIR" submodule update --init --recursive --quiet 2>/dev/null || warn "submodule update failed; vendor-skill resolution may be incomplete"
  else
    log "  ↓ cloning $REPO_URL → $XDG_SOURCE_DIR" >&2
    mkdir -p "$(dirname "$XDG_SOURCE_DIR")"
    git clone --quiet --single-branch --depth 1 --recurse-submodules "$REPO_URL" "$XDG_SOURCE_DIR" >&2
  fi

  if [ -d "$XDG_SOURCE_DIR/skills" ] && [ -d "$XDG_SOURCE_DIR/bin" ]; then
    chmod +x "$XDG_SOURCE_DIR/bin"/safer-* 2>/dev/null || true
    printf '%s\n' "$XDG_SOURCE_DIR"
    return 0
  fi
  err "clone at $XDG_SOURCE_DIR is missing skills/ or bin/"
  return 1
}

resolved_path() (
  local target="$1"
  local dir
  local link
  local base

  while [ -L "$target" ]; do
    dir="$(cd "$(dirname "$target")" && pwd -P)"
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *)  target="$dir/$link" ;;
    esac
  done

  if [ -d "$target" ]; then
    cd "$target" && pwd -P
    return 0
  fi

  dir="$(cd "$(dirname "$target")" && pwd -P)"
  base="$(basename "$target")"
  printf '%s/%s\n' "$dir" "$base"
)

check_cmd() {
  local cmd="$1"
  local why="$2"
  if command -v "$cmd" >/dev/null 2>&1; then
    log "  ✓ $cmd — $(command -v "$cmd")"
  else
    warn "missing: $cmd ($why)"
  fi
}

ensure_dir() {
  local path="$1"
  if [ "$CHECK_ONLY" -eq 1 ]; then
    [ -d "$path" ] || warn "missing directory: $path"
    return 0
  fi
  mkdir -p "$path"
}

ensure_plugin_link() {
  if [ -L "$PLUGIN_LINK" ] || [ -d "$PLUGIN_LINK" ]; then
    if [ -L "$PLUGIN_LINK" ] && [ ! -e "$PLUGIN_LINK" ]; then
      if [ "$CHECK_ONLY" -eq 1 ]; then
        warn "$PLUGIN_LINK is a dangling symlink; will re-link to $SOURCE_DIR"
        return 0
      fi
      log "  ↻ removing dangling $PLUGIN_LINK"
      rm -f "$PLUGIN_LINK"
    else
      local current
      current="$(resolved_path "$PLUGIN_LINK")"
      if [ "$current" = "$(resolved_path "$SOURCE_DIR")" ]; then
        log "  ✓ plugin root linked at $PLUGIN_LINK"
        return 0
      fi
      if [ -L "$PLUGIN_LINK" ]; then
        if [ "$CHECK_ONLY" -eq 1 ]; then
          warn "$PLUGIN_LINK points to stale target ($current); will re-link to $SOURCE_DIR"
          return 0
        fi
        log "  ↻ updating $PLUGIN_LINK: $current → $SOURCE_DIR"
        rm -f "$PLUGIN_LINK"
      else
        err "$PLUGIN_LINK exists as a real directory and points elsewhere: $current"
        return 1
      fi
    fi
  fi

  if [ "$CHECK_ONLY" -eq 1 ]; then
    warn "missing plugin link: $PLUGIN_LINK"
    return 0
  fi

  ln -s "$SOURCE_DIR" "$PLUGIN_LINK"
  log "  ✓ linked plugin root to $PLUGIN_LINK"
}

write_wrapper() {
  local skill_name="$1"
  local wrapper_dir="$SKILLS_DIR/safer-$skill_name"
  local wrapper_file="$wrapper_dir/SKILL.md"
  local display_name="safer:$skill_name"

  if [ "$CHECK_ONLY" -eq 1 ]; then
    if [ -f "$wrapper_file" ] && grep -Fq "$MARKER" "$wrapper_file"; then
      log "  ✓ wrapper present: $display_name"
    else
      warn "missing wrapper: $display_name ($wrapper_file)"
    fi
    return 0
  fi

  if [ -e "$wrapper_dir" ] && { [ ! -f "$wrapper_file" ] || ! grep -Fq "$MARKER" "$wrapper_file"; }; then
    err "refusing to overwrite non-generated wrapper at $wrapper_dir"
    return 1
  fi

  mkdir -p "$wrapper_dir"
  cat > "$wrapper_file" <<EOF
---
name: "$display_name"
description: "Codex compatibility wrapper for the safer-by-default '$skill_name' skill installed locally."
---

$MARKER

# $display_name

This wrapper forwards to the local \`safer-by-default\` repo.

Before acting:
1. Read \`../safer-by-default/PRINCIPLES.md\`.
2. Read \`../safer-by-default/skills/$skill_name/SKILL.md\`.
3. Treat \`../safer-by-default\` as the plugin root.
4. Treat \`AskUserQuestion\` in the upstream instructions as a concise user question or Codex user-input request.
5. Treat upstream tool labels (\`Bash\`, \`Read\`, \`Write\`, \`Edit\`, \`Grep\`, \`Glob\`) as the closest available Codex tools.
6. Prefer \`safer-*\` binaries from \`PATH\`; if missing, use \`../safer-by-default/bin/<command>\` directly.

Use this skill when the user explicitly asks for \`$display_name\` or for the safer-by-default \`$skill_name\` workflow.
EOF
  log "  ✓ installed wrapper: $display_name"
}

link_bin() {
  local source_file="$1"
  local bin_name
  local dest_file
  local current

  bin_name="$(basename "$source_file")"
  dest_file="$BIN_LINK_DIR/$bin_name"

  if [ -L "$dest_file" ] && [ ! -e "$dest_file" ]; then
    if [ "$CHECK_ONLY" -eq 1 ]; then
      warn "$dest_file is a dangling symlink; will re-link to $source_file"
      return 0
    fi
    log "  ↻ removing dangling $dest_file"
    rm -f "$dest_file"
  elif [ -L "$dest_file" ] || [ -f "$dest_file" ]; then
    current="$(resolved_path "$dest_file")"
    if [ "$current" = "$(resolved_path "$source_file")" ]; then
      log "  ✓ binary linked: $bin_name"
      return 0
    fi
    if [ -L "$dest_file" ]; then
      if [ "$CHECK_ONLY" -eq 1 ]; then
        warn "$dest_file points to stale target ($current); will re-link to $source_file"
        return 0
      fi
      log "  ↻ updating $dest_file: $current → $source_file"
      rm -f "$dest_file"
    else
      err "$dest_file already exists as a regular file (not a symlink): $current"
      return 1
    fi
  fi

  if [ "$CHECK_ONLY" -eq 1 ]; then
    warn "missing binary link: $dest_file"
    return 0
  fi

  ln -s "$source_file" "$dest_file"
  log "  ✓ linked binary: $dest_file"
}

log "safer-by-default Codex setup"
log "  script dir:   $SCRIPT_DIR"
log "  codex home:   $CODEX_HOME"
log "  skills dir:   $SKILLS_DIR"
log "  bin link dir: $BIN_LINK_DIR"
log ""

log "Resolving safer-by-default source..."
SOURCE_DIR="$(resolve_source_dir)" || { err "could not resolve a source dir; aborting"; exit 1; }
log ""

log "Checking recommended dependencies..."
check_cmd bash "required by safer-* helper scripts"
check_cmd git "required by safer-slug and repo-aware workflows"
check_cmd gh "required by GitHub-backed safer workflows"
check_cmd bun "used by the TypeScript bootstrap flow in some repos"
if command -v gh >/dev/null 2>&1; then
  if gh auth status >/dev/null 2>&1; then
    log "  ✓ gh authenticated"
  else
    warn "gh is installed but not authenticated. GitHub-backed skills will not complete until you run: gh auth login"
  fi
fi
log ""

log "Preparing directories..."
ensure_dir "$SKILLS_DIR"
ensure_dir "$BIN_LINK_DIR"
ensure_dir "$STATE_DIR/analytics"
if [ "$CHECK_ONLY" -eq 0 ] && [ ! -f "$STATE_DIR/analytics/events.jsonl" ]; then
  : > "$STATE_DIR/analytics/events.jsonl"
  log "  ✓ created $STATE_DIR/analytics/events.jsonl"
fi
log ""

log "Registering plugin root..."
ensure_plugin_link
log ""

log "Installing skill wrappers..."
for skill_dir in "$SOURCE_DIR"/skills/*; do
  [ -d "$skill_dir" ] || continue
  [ -f "$skill_dir/SKILL.md" ] || continue
  write_wrapper "$(basename "$skill_dir")"
done

# v0.2.0 rename cleanup: remove ONLY the known retired wrapper from earlier
# versions. Broad-scope cleanup ("every safer-* whose suffix isn't in the
# current skills list") risks removing locally-installed unrelated wrappers;
# the narrow form is sufficient for the spec→contract rename. Future renames
# extend this explicit retired-name list.
RETIRED_WRAPPERS=("safer-spec")
for retired in "${RETIRED_WRAPPERS[@]}"; do
  retired_dir="$SKILLS_DIR/$retired"
  retired_file="$retired_dir/SKILL.md"
  [ -d "$retired_dir" ] || continue
  if [ "$CHECK_ONLY" -eq 1 ]; then
    if [ -f "$retired_file" ] && grep -Fq "$MARKER" "$retired_file"; then
      warn "stale retired wrapper present: $retired_dir (would be removed)"
    fi
    continue
  fi
  if [ -f "$retired_file" ] && grep -Fq "$MARKER" "$retired_file"; then
    rm -rf "$retired_dir"
    log "  ↻ removed retired wrapper: $retired_dir"
  else
    # Non-generated wrapper at retired path; refuse to delete.
    warn "retired wrapper path $retired_dir exists without the generated marker; leaving in place"
  fi
done
log ""

log "Linking safer binaries..."
for source_file in "$SOURCE_DIR"/bin/safer-*; do
  [ -f "$source_file" ] || continue
  link_bin "$source_file"
done
log ""

if [ "$CHECK_ONLY" -eq 1 ]; then
  log "--check complete."
else
  log "Codex setup complete."
  log "Restart Codex to pick up the new skills."
fi
