#!/usr/bin/env bash
# safer-acg-sync — regenerate the ACG rule table in skills/typescript/SKILL.tmpl.
#
# Reads:
#   skills/setup/SKILL.tmpl — for the install line `eslint-plugin-agent-code-guard@<spec>`.
#   The resolved ACG source — local node_modules (preferred, decoded via node -e)
#     or GitHub at the matching tag (TS source, parsed via awk).
#   skills/typescript/acg-rationale.json — hand-curated rule rationale + principle anchors.
#
# Writes:
#   skills/typescript/SKILL.tmpl — between `<!-- BEGIN: acg-mapping -->` and
#   `<!-- END: acg-mapping -->` markers, the rendered table.
#
# After this script runs, run `bin/safer-gen-skills` to render SKILL.md from
# the updated SKILL.tmpl. Writing into the .tmpl (the human-edited source)
# rather than the .md (the codegen artifact) means the table survives every
# `safer-gen-skills` invocation; the alternative writes get destroyed on the
# next codegen pass.
#
# Fails (exit 1) if ACG ships a rule that the rationale-map doesn't cover.
# Warns (stderr) if rationale-map entries exist with no matching ACG rule.
#
# Usage: ./bin/safer-acg-sync && ./bin/safer-gen-skills
#   (run from the safer-by-default repo root)
#
# Trigger: when skills/setup/SKILL.tmpl's install line for eslint-plugin-agent-code-guard
# changes. PRINCIPLES.md heading rename/renumber requires updating the principle_slug
# function below to match the new GitHub anchor.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SETUP_SKILL="$REPO_ROOT/skills/setup/SKILL.tmpl"
TS_SKILL="$REPO_ROOT/skills/typescript/SKILL.tmpl"
RATIONALE="$REPO_ROOT/skills/typescript/acg-rationale.json"

# ---- Preflight ----
for cmd in jq node; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "ERROR: $cmd is required but not on PATH" >&2; exit 2; }
done
[ -f "$SETUP_SKILL" ] || { echo "ERROR: $SETUP_SKILL missing" >&2; exit 2; }
[ -f "$TS_SKILL"    ] || { echo "ERROR: $TS_SKILL missing"    >&2; exit 2; }
[ -f "$RATIONALE"   ] || { echo "ERROR: $RATIONALE missing — create it with rule rationale entries" >&2; exit 2; }

# ---- Single tempdir + cleanup ----
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
ACG_SRC="$TMP_DIR/acg-src"
RULES_TSV="$TMP_DIR/rules.tsv"
TABLE="$TMP_DIR/table.md"

# ---- Step 1: find the install spec ----
INSTALL_LINE=$(grep -E 'eslint-plugin-agent-code-guard@' "$SETUP_SKILL" | head -1 || true)
[ -n "$INSTALL_LINE" ] || { echo "ERROR: no eslint-plugin-agent-code-guard@<spec> line in $SETUP_SKILL" >&2; exit 2; }

SPEC=$(echo "$INSTALL_LINE" | grep -oE 'eslint-plugin-agent-code-guard@[^ "'"'"']+' | sed 's/eslint-plugin-agent-code-guard@//' | head -1)
[ -n "$SPEC" ] || { echo "ERROR: failed to parse install spec from line: $INSTALL_LINE" >&2; exit 2; }

# Resolve ^0.0.2 → 0.0.2 (lowest-bound resolution per WS4 v6 spec).
TAG="v$(echo "$SPEC" | sed 's/^[\^~>=<]//;s/[<>=].*//')"

echo "install-line spec: $SPEC"
echo "resolved tag:      $TAG"

# ---- Step 2: enumerate rules ----
# Two source paths:
#   (a) local node_modules: decode the ACG API via node -e require(). Authoritative.
#   (b) GitHub fallback: fetch src/index.ts and awk-parse it. Used only when the
#       package is not installed locally. Awk on TS source is the only option here
#       because we cannot require() a package that is not installed.
SOURCE_KIND=""
LOCAL_PKG_DIR="$REPO_ROOT/node_modules/eslint-plugin-agent-code-guard"

if [ -d "$LOCAL_PKG_DIR" ] && node -e "require.resolve('eslint-plugin-agent-code-guard')" \
    --require "$LOCAL_PKG_DIR/package.json" >/dev/null 2>&1; then
  SOURCE_KIND="local-api"
  echo "source:            local node_modules (decoded via node API)"
  # Emit "<preset>\t<rule>\t<severity>" lines from the ACG configs object.
  ( cd "$REPO_ROOT" && node -e '
    const acg = require("eslint-plugin-agent-code-guard");
    if (!acg.configs) { process.stderr.write("ERROR: ACG package has no .configs export\n"); process.exit(2); }
    const presets = ["recommended", "integrationTests"];
    for (const preset of presets) {
      const cfg = acg.configs[preset];
      if (!cfg || !cfg.rules) continue;
      for (const [name, sev] of Object.entries(cfg.rules)) {
        if (!name.startsWith("agent-code-guard/")) continue;
        const rule = name.slice("agent-code-guard/".length);
        const severity = Array.isArray(sev) ? sev[0] : sev;
        process.stdout.write(preset + "\t" + rule + "\t" + severity + "\n");
      }
    }
  ' ) > "$RULES_TSV"
elif command -v gh >/dev/null 2>&1; then
  SOURCE_KIND="github-source"
  echo "source:            chughtapan/agent-code-guard@$TAG (GitHub TS source)"
  # v0.0.8+ moved rule registrations across files. Fetch all the candidate
  # files; concatenate; awk over the union. Each file may contribute one
  # preset block (recommendedSyntaxRuleEntries, integrationTestRuleEntries,
  # recommendedArchitectureRuleEntries, architecturePresetRuleEntries).
  ACG_SOURCES="$TMP_DIR/acg-sources.ts"
  : > "$ACG_SOURCES"
  for path in src/rules/registry.ts src/rules/architecture/plugin-rules.ts src/index.ts; do
    gh api "repos/chughtapan/agent-code-guard/contents/$path?ref=$TAG" \
      --jq '.content' 2>/dev/null | base64 -d >> "$ACG_SOURCES" 2>/dev/null || true
  done
  [ -s "$ACG_SOURCES" ] || { echo "ERROR: failed to fetch any source from chughtapan/agent-code-guard@$TAG" >&2; exit 2; }
  awk '
    /recommendedSyntaxRuleEntries[^{]*\{/      { preset = "recommended"; next }
    /integrationTestRuleEntries[^{]*\{/        { preset = "integrationTests"; next }
    /recommendedArchitectureRuleEntries[^{]*\{/{ preset = "recommended"; next }
    /architecturePresetRuleEntries[^{]*\{/     { preset = "architecture"; next }
    /^[[:space:]]*\};?[[:space:]]*$/           { preset = "" }
    preset != "" && match($0, /"agent-code-guard\/[a-z-]+":[[:space:]]*"(error|warn)"/) {
      chunk = substr($0, RSTART, RLENGTH)
      n = index(chunk, "/")
      rest = substr(chunk, n + 1)
      e = index(rest, "\"")
      rule = substr(rest, 1, e - 1)
      sev = (chunk ~ /"warn"/) ? "warn" : "error"
      printf "%s\t%s\t%s\n", preset, rule, sev
    }
  ' "$ACG_SOURCES" | sort -u > "$RULES_TSV"
else
  echo "ERROR: no local node_modules and gh CLI not on PATH; cannot fetch ACG source" >&2
  exit 2
fi

RULE_COUNT=$(wc -l < "$RULES_TSV" | tr -d ' ')
echo "rule count:        $RULE_COUNT"
[ "$RULE_COUNT" -gt 0 ] || { echo "ERROR: parsed zero rules from ACG source ($SOURCE_KIND)" >&2; exit 2; }

# ---- Step 3: check rationale-map coverage ----
# Dedup rules across presets — the same rule can appear in recommended AND
# architecture presets; we only need one rationale entry per rule.
UNMAPPED=()
while IFS= read -r rule; do
  jq -e --arg r "$rule" '.[$r]' "$RATIONALE" >/dev/null 2>&1 || UNMAPPED+=("$rule")
done < <(cut -f2 "$RULES_TSV" | sort -u)

if [ "${#UNMAPPED[@]}" -gt 0 ]; then
  echo "ERROR: rules in ACG@$TAG with no entry in $RATIONALE:" >&2
  for r in "${UNMAPPED[@]}"; do echo "  - $r" >&2; done
  echo "Add rationale entries for these rules and re-run." >&2
  exit 1
fi

# Warn on orphan rationale entries (in map, not in ACG).
ACG_RULES_SORTED=$(cut -f2 "$RULES_TSV" | sort -u)
MAP_RULES_SORTED=$(jq -r 'keys[]' "$RATIONALE" | sort -u)
ORPHANS=$(comm -23 <(echo "$MAP_RULES_SORTED") <(echo "$ACG_RULES_SORTED") || true)
if [ -n "$ORPHANS" ]; then
  echo "WARNING: rationale-map entries with no matching ACG@$TAG rule:" >&2
  echo "$ORPHANS" | sed 's/^/  - /' >&2
  echo "(kept in map for historical reference; consider removing if not needed)" >&2
fi

# ---- Step 4: principle anchor mapping ----
# GitHub auto-generates heading anchors. The slugs below are the literal anchors
# rendered by GitHub for PRINCIPLES.md heading lines `## <N>. <title> — <subtitle>`.
# When PRINCIPLES.md heading text changes, update the matching slug here.
principle_short_title() {
  case "$1" in
    1) echo "Types beat tests" ;;
    2) echo "Validate at every boundary" ;;
    3) echo "Errors are typed, not thrown" ;;
    4) echo "Exhaustiveness over optionality" ;;
    5) echo "The Junior Dev Rule" ;;
    6) echo "The Budget Gate" ;;
    7) echo "The Brake" ;;
    8) echo "The Ratchet" ;;
    *) echo "principle $1" ;;
  esac
}

principle_slug() {
  case "$1" in
    1) echo "1-types-beat-tests--move-constraints-into-the-type-system" ;;
    2) echo "2-validate-at-every-boundary--schemas-where-data-enters-types-inside" ;;
    3) echo "3-errors-are-typed-not-thrown--tagged-errors-or-typed-results-no-raw-throws-no-silent-catches" ;;
    4) echo "4-exhaustiveness-over-optionality--every-branch-handled-switches-end-in-never" ;;
    5) echo "5-the-junior-dev-rule--discipline-over-capability" ;;
    6) echo "6-the-budget-gate--scope-is-a-hard-budget" ;;
    7) echo "7-the-brake--stop-rules-are-literal" ;;
    8) echo "8-the-ratchet--escalate-up-not-around" ;;
    *) echo "" ;;
  esac
}

render_anchors() {
  # Input: comma-separated principle numbers, e.g. "3,4".
  # Output: comma-separated markdown links to PRINCIPLES.md anchors.
  local input="$1"
  local out=""
  local IFS=','
  for n in $input; do
    n="${n// /}"
    local title
    title=$(principle_short_title "$n")
    local slug
    slug=$(principle_slug "$n")
    if [ -z "$slug" ]; then
      [ -z "$out" ] && out="**P$n**" || out="$out, **P$n**"
    else
      local link="[principle $n — $title](../../PRINCIPLES.md#$slug)"
      [ -z "$out" ] && out="$link" || out="$out, $link"
    fi
  done
  echo "$out"
}

# ---- Step 5: render the table ----
# Group rules by category. Category derived from docs/rules/<category>/<rule>.md.
# A rule may appear in multiple presets (recommended + architecture); collapse
# preset values into a comma list, take the strictest severity (error > warn).
CATEGORIES_TSV="$TMP_DIR/categories.tsv"   # rule \t category
: > "$CATEGORIES_TSV"
for cat in architecture async-flow effect manual-algebra safety testing tooling; do
  gh api "repos/chughtapan/agent-code-guard/contents/docs/rules/$cat?ref=$TAG" \
    --jq '.[].name' 2>/dev/null \
    | sed -n 's/\.md$//p' \
    | awk -v c="$cat" '{ printf "%s\t%s\n", $0, c }' >> "$CATEGORIES_TSV" || true
done

# Collapse rules across presets: rule \t presets-csv \t severity (error wins)
COLLAPSED_TSV="$TMP_DIR/collapsed.tsv"
awk -F'\t' '
  {
    rule = $2
    if (seen[rule]) {
      presets[rule] = presets[rule] "," $1
      if ($3 == "error") sev[rule] = "error"
    } else {
      seen[rule] = 1
      presets[rule] = $1
      sev[rule] = $3
    }
  }
  END { for (r in presets) printf "%s\t%s\t%s\n", r, presets[r], sev[r] }
' "$RULES_TSV" | sort > "$COLLAPSED_TSV"

# Count rules that have BOTH a registry entry and a docs page; that's what
# the table actually renders. Source-only rules (e.g. internal validators
# without a docs/rules/<cat>/<rule>.md page) are dropped silently.
RENDERED_COUNT=$(comm -12 <(cut -f1 "$CATEGORIES_TSV" | sort -u) <(cut -f1 "$COLLAPSED_TSV" | sort -u) | wc -l | tr -d ' ')

cat > "$TABLE" <<EOF
**Resolved version:** \`eslint-plugin-agent-code-guard@$SPEC\` (from \`skills/setup/SKILL.tmpl\`) → ACG \`$TAG\` ships **$RENDERED_COUNT documented rules** across 7 categories.

EOF

# Render one table per category in this order (architecture first, largest):
for cat in architecture async-flow effect manual-algebra safety testing tooling; do
  cat_rules=$(grep -F "	$cat" "$CATEGORIES_TSV" | cut -f1 | sort)
  [ -z "$cat_rules" ] && continue
  cat_label=$(echo "$cat" | sed 's/-/ /g' | awk '{ for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2) } 1')
  cat_count=$(echo "$cat_rules" | wc -l | tr -d ' ')
  cat >> "$TABLE" <<EOF
### $cat_label ($cat_count)

| Rule | Preset(s) | Severity | Principle anchor(s) | Rationale | Doc |
|---|---|---|---|---|---|
EOF
  for rule in $cat_rules; do
    row=$(grep -F "$rule"$'\t' "$COLLAPSED_TSV" | head -1)
    [ -z "$row" ] && continue
    presets=$(echo "$row" | cut -f2)
    severity=$(echo "$row" | cut -f3)
    raw_anchors=$(jq -r --arg r "$rule" '.[$r].principle_anchors | map(tostring) | join(",")' "$RATIONALE")
    anchors=$(render_anchors "$raw_anchors")
    rationale=$(jq -r --arg r "$rule" '.[$r].rationale' "$RATIONALE")
    github_url="https://github.com/chughtapan/agent-code-guard/blob/$TAG/docs/rules/$cat/$rule.md"
    if [ "$SOURCE_KIND" = "local-api" ]; then
      doc_cell="\`node_modules/eslint-plugin-agent-code-guard/docs/rules/$cat/$rule.md\` / [github]($github_url)"
    else
      doc_cell="[github]($github_url)"
    fi
    echo "| \`$rule\` | \`$presets\` | $severity | $anchors | $rationale | $doc_cell |" >> "$TABLE"
  done
  echo "" >> "$TABLE"
done

cat >> "$TABLE" <<EOF

*Maintenance:* hand-maintained rationale-map in \`skills/typescript/acg-rationale.json\`. Updated by \`bin/safer-acg-sync\` when \`skills/setup/SKILL.tmpl\`'s ACG install line changes. After running the sync, run \`bin/safer-gen-skills\` to regenerate SKILL.md. Principle anchors link to \`PRINCIPLES.md\` headings; if a heading is renamed, update the slug map in \`bin/safer-acg-sync\`.
EOF

# ---- Step 6: splice into skills/typescript/SKILL.tmpl between markers ----
grep -q '<!-- BEGIN: acg-mapping -->' "$TS_SKILL" \
  || { echo "ERROR: $TS_SKILL missing <!-- BEGIN: acg-mapping --> marker" >&2; exit 2; }

awk -v table_file="$TABLE" '
  /<!-- BEGIN: acg-mapping -->/ {
    print
    while ((getline line < table_file) > 0) print line
    close(table_file)
    skip = 1
    next
  }
  /<!-- END: acg-mapping -->/ {
    skip = 0
    print
    next
  }
  !skip { print }
' "$TS_SKILL" > "$TS_SKILL.tmp" && mv "$TS_SKILL.tmp" "$TS_SKILL"

echo "wrote table:       $TS_SKILL between markers"
echo "done."
