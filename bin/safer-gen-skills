#!/usr/bin/env bash
# safer-gen-skills — render skills/<name>/SKILL.md from skills/<name>/SKILL.tmpl
#
# The .tmpl is the human-edited source. It contains the YAML frontmatter and
# modality-specific content. The generator inlines PRINCIPLES.md verbatim where
# {{> principles}} appears, inlines a vendor skill body where
# {{> vendor-skill:<slug>}} appears (stripping the vendor file's leading YAML
# frontmatter block), and stamps an AUTO-GENERATED marker right after the
# wrapper frontmatter so CI / humans can detect manual edits to the rendered
# file.
#
# Usage:
#   bin/safer-gen-skills                    # render every skills/*/SKILL.tmpl
#   bin/safer-gen-skills --check            # exit non-zero if any SKILL.md is stale
#   bin/safer-gen-skills --check --release  # also fail if the literal sentinel
#                                           # __SAFER_SPEC_VERSION__ survives in
#                                           # any committed SKILL.tmpl/SKILL.md
#
# Two-phase sentinel rationale: during the v0.2.0 integration PR, source
# carries the literal __SAFER_SPEC_VERSION__ as an edit-point marker for the
# install-command substitution. The integration PR's final commit replaces
# the sentinel line with the dogfood `link:` install block. Bare `--check`
# is the dev-loop form and stays green while source carries the sentinel;
# `--check --release` is the release-mode form and fails if the sentinel
# survived to the release branch. CI on release/* branches runs the latter.
#
# The generator is idempotent. Skills that don't yet have a .tmpl are skipped
# (no SKILL.md is touched), so migration can land one skill at a time.
set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PRINCIPLES_FILE="$PLUGIN_DIR/PRINCIPLES.md"
VENDOR_SKILLS_ROOT="$PLUGIN_DIR/vendor/safer-spec-development/skills"
SENTINEL='__SAFER_SPEC_VERSION__'
# Single source of truth for the vendor-skill directive shape. Both the
# shell-side pre-validator (grep) and the awk-side renderer match against
# this so they cannot drift.
VENDOR_DIRECTIVE_RE='^\{\{> vendor-skill:[a-z0-9-]+\}\}$'
MARKER='<!-- AUTO-GENERATED from this directory'\''s SKILL.tmpl + PRINCIPLES.md. Do not edit; edit the .tmpl and regenerate via bin/safer-gen-skills. -->'

CHECK_ONLY=0
RELEASE_MODE=0

while [ $# -gt 0 ]; do
  case "$1" in
    --check) CHECK_ONLY=1; shift ;;
    --release) RELEASE_MODE=1; shift ;;
    -h|--help)
      sed -n '2,/^set/p' "$0" | sed 's/^# *//;s/^#//'
      exit 0
      ;;
    *) echo "ERROR: unknown flag: $1" >&2; exit 1 ;;
  esac
done

if [ "$RELEASE_MODE" -eq 1 ] && [ "$CHECK_ONLY" -eq 0 ]; then
  echo "ERROR: --release requires --check (release-mode is a check-only gate)" >&2
  exit 1
fi

[ -f "$PRINCIPLES_FILE" ] || { echo "ERROR: $PRINCIPLES_FILE not found" >&2; exit 1; }

# Pre-validate every {{> vendor-skill:<slug>}} directive in every template
# against the actual vendor tree. awk's `getline` returns 0 on missing files,
# producing silent empty output; this loop makes the failure mode loud.
validate_vendor_directives() {
  local tmpl="$1"
  local missing=0
  while IFS= read -r slug; do
    [ -z "$slug" ] && continue
    if ! printf '%s\n' "$slug" | grep -qE '^[a-z0-9-]+$'; then
      echo "ERROR: vendor-skill slug '$slug' in $tmpl does not match ^[a-z0-9-]+$" >&2
      missing=1
      continue
    fi
    local vendor_path="$VENDOR_SKILLS_ROOT/$slug/SKILL.md"
    if [ ! -f "$vendor_path" ]; then
      echo "ERROR: vendor-skill $slug not found at $vendor_path (referenced from $tmpl)" >&2
      missing=1
      continue
    fi
    # Refuse to inline if any component on the path to the vendor SKILL.md
    # is a symlink, OR if the canonicalized path escapes $VENDOR_SKILLS_ROOT.
    # The supply-chain threat model: a compromised sister-repo merge could
    # plant either the leaf `SKILL.md` OR an enclosing directory (e.g., the
    # per-slug directory) as a symlink. Git represents both shapes the same
    # way at the tree level. The leaf-only check left the harder half open;
    # canonicalize+prefix-check closes both cases atomically.
    local resolved_vendor_root resolved_path
    resolved_vendor_root=$(readlink -f -- "$VENDOR_SKILLS_ROOT" 2>/dev/null) || resolved_vendor_root=""
    resolved_path=$(readlink -f -- "$vendor_path" 2>/dev/null) || resolved_path=""
    if [ -z "$resolved_vendor_root" ] || [ -z "$resolved_path" ]; then
      echo "ERROR: vendor-skill $slug at $vendor_path failed to canonicalize (referenced from $tmpl); refusing to inline" >&2
      missing=1
      continue
    fi
    case "$resolved_path" in
      "$resolved_vendor_root"/*) : ;;
      *)
        echo "ERROR: vendor-skill $slug at $vendor_path resolves outside \$VENDOR_SKILLS_ROOT (resolved=$resolved_path; referenced from $tmpl); refusing to inline" >&2
        missing=1
        continue
        ;;
    esac
    # Even if the canonical path is inside the vendor root, refuse if any
    # component along the way is a symlink — directory symlinks pointing
    # *within* the same vendor root are still tamper signals (the sister
    # repo's tree should be regular files end-to-end).
    local cur="$vendor_path"
    while [ "$cur" != "$VENDOR_SKILLS_ROOT" ] && [ "$cur" != "/" ] && [ -n "$cur" ]; do
      if [ -L "$cur" ]; then
        echo "ERROR: vendor-skill $slug has a symlink at path component $cur (referenced from $tmpl); refusing to inline" >&2
        missing=1
        break
      fi
      cur=$(dirname -- "$cur")
    done
  done < <(grep -oE "$VENDOR_DIRECTIVE_RE" "$tmpl" | sed -E 's/^\{\{> vendor-skill:([a-z0-9-]+)\}\}$/\1/')
  return "$missing"
}

render_one() {
  local tmpl="$1"
  awk \
    -v principles_file="$PRINCIPLES_FILE" \
    -v vendor_root="$VENDOR_SKILLS_ROOT" \
    -v marker="$MARKER" \
    -v vendor_directive_re="$VENDOR_DIRECTIVE_RE" '
    BEGIN { fm = 0; injected = 0 }
    /^---$/ {
      print
      fm++
      if (fm == 2 && !injected) {
        print ""
        print marker
        injected = 1
      }
      next
    }
    /^\{\{> principles\}\}$/ {
      while ((getline line < principles_file) > 0) print line
      close(principles_file)
      next
    }
    $0 ~ vendor_directive_re {
      slug = $0
      sub(/^\{\{> vendor-skill:/, "", slug)
      sub(/\}\}$/, "", slug)
      vendor_path = vendor_root "/" slug "/SKILL.md"
      in_fm = 0
      fm_closed = 0
      first_line = 1
      h1_demoted = 0
      while ((getline line < vendor_path) > 0) {
        if (first_line) {
          first_line = 0
          if (line == "---") {
            in_fm = 1
            continue
          }
        }
        if (in_fm && !fm_closed) {
          if (line == "---") { fm_closed = 1; continue }
          continue
        }
        # Demote the vendor body’s first H1 to H2. The wrapper file already
        # carries its own H1 (e.g. `# /safer:spec-init`); without this the
        # generated SKILL.md emits two H1s and the document outline reads as
        # two top-level sections.
        if (!h1_demoted && line ~ /^# /) {
          sub(/^# /, "## ", line)
          h1_demoted = 1
        }
        print line
      }
      close(vendor_path)
      next
    }
    { print }
  ' "$tmpl"
}

STALE=0
RENDERED=0
TOTAL=0
INVALID=0

for tmpl in "$PLUGIN_DIR"/skills/*/SKILL.tmpl; do
  [ -f "$tmpl" ] || continue
  TOTAL=$((TOTAL + 1))
  out="$(dirname "$tmpl")/SKILL.md"
  if ! validate_vendor_directives "$tmpl"; then
    INVALID=$((INVALID + 1))
    continue
  fi
  rendered=$(render_one "$tmpl")

  if [ "$CHECK_ONLY" -eq 1 ]; then
    if [ ! -f "$out" ] || ! diff -q <(printf '%s' "$rendered") "$out" >/dev/null 2>&1; then
      echo "STALE: $out"
      STALE=$((STALE + 1))
    fi
  else
    printf '%s' "$rendered" > "$out"
    RENDERED=$((RENDERED + 1))
  fi
done

# Skills without a .tmpl are flagged so we know how migration is progressing.
PENDING=0
for d in "$PLUGIN_DIR"/skills/*/; do
  [ -f "$d/SKILL.md" ] || continue
  [ -f "$d/SKILL.tmpl" ] && continue
  PENDING=$((PENDING + 1))
done

SENTINEL_HITS=0
if [ "$CHECK_ONLY" -eq 1 ] && [ "$RELEASE_MODE" -eq 1 ]; then
  # Sentinel arm only fires under --check --release. Bare --check skips this
  # so dev branches stay green while the v0.2.0 integration PR is still
  # authoring the substitution.
  while IFS= read -r hit; do
    [ -z "$hit" ] && continue
    SENTINEL_HITS=$((SENTINEL_HITS + 1))
    echo "SENTINEL: $hit"
  done < <(grep -rnF "$SENTINEL" "$PLUGIN_DIR/skills" --include='SKILL.tmpl' --include='SKILL.md' 2>/dev/null || true)
fi

if [ "$CHECK_ONLY" -eq 1 ]; then
  echo "checked: $TOTAL skills with .tmpl, $STALE stale"
  echo "pending migration (no .tmpl yet): $PENDING"
  if [ "$INVALID" -gt 0 ]; then
    echo "invalid vendor-skill directives in $INVALID templates"
  fi
  if [ "$RELEASE_MODE" -eq 1 ]; then
    if [ "$SENTINEL_HITS" -gt 0 ]; then
      echo "release-mode: sentinel '$SENTINEL' survived in $SENTINEL_HITS files"
    else
      echo "release-mode: no sentinel '$SENTINEL' found in skills/"
    fi
  fi
  # Any combined failure exits 1; the gate is a binary signal so a high
  # combined count cannot wrap past 255 and look green.
  if [ "$STALE" -gt 0 ] || [ "$INVALID" -gt 0 ] || [ "$SENTINEL_HITS" -gt 0 ]; then
    exit 1
  fi
  exit 0
fi

if [ "$INVALID" -gt 0 ]; then
  echo "ERROR: $INVALID template(s) failed vendor-skill pre-validation; rendered $RENDERED of $TOTAL" >&2
  exit 1
fi

echo "rendered: $RENDERED of $TOTAL skills with .tmpl"
echo "pending migration (no .tmpl yet): $PENDING"
